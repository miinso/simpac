{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "bazel-build",
            "type": "shell",
            "command": "bazel",
            "args": [
                "build",
                "//${relativeFileDirname}:${fileBasenameNoExtension}",
            ],
            "windows": {
                "type": "process",
                "command": "powershell",
                "args": [
                    "-Command",
                    "& {$target = ('${relativeFileDirname}:${fileBasenameNoExtension}' -replace '\\\\', '/'); bazel build //$target;}"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
        },
        {
            "label": "bazel-build-debug",
            "type": "shell",
            "command": "bazel",
            "args": [
                "build",
                "-c",
                "dbg",
                "--copt=-g",
                "--strip=never",
                "//${relativeFileDirname}:${fileBasenameNoExtension}"
            ],
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}