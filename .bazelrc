# Auto-select platform config
build --enable_platform_specific_config

# Host tools (genrules, code generators)
build:windows --host_cxxopt=/std:c++17
build:windows --host_copt=/FS
build:linux --host_cxxopt=-std=c++17
build:macos --host_cxxopt=-std=c++17

# Linux/macOS: default to native builds (exclude wasm)
build:linux --cxxopt=-std=c++17
build:linux --build_tag_filters=-wasm
build:macos --cxxopt=-std=c++17
build:macos --build_tag_filters=-wasm

# Windows: default to native builds (exclude wasm)
build:windows --cxxopt=/std:c++17
build:windows --copt=/FS                   # parallel PDB writes
build:windows --build_tag_filters=-wasm
# for profiler: --copt=/Zi --linkopt=/DEBUG --linkopt=/PROFILE

# Wasm builds: use --config=wasm
build:wasm --build_tag_filters=wasm

# build:windows --enable_runfiles # https://github.com/bazelbuild/bazel/issues/8843

# build --incompatible_enable_cc_toolchain_resolution

# build all targets (except wasm):
# `bazel build ...`

# build only wasm targets:
# `bazel build ... --config=wasm`
